# =============================================================================
# ENVIRONMENT VARIABLES - Copy to .env and fill in values
# =============================================================================

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/codemix_nlp
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=codemix_nlp
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=redis
REDIS_PORT=6379

# JWT (Generate with: openssl genrsa -out private_key.pem 2048)
JWT_SECRET_KEY=your-super-secret-key-minimum-32-characters-change-in-production
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# RSA Keys (for RS256 - base64 encoded)
# Generate: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY_PATH=./keys/private_key.pem
JWT_PUBLIC_KEY_PATH=./keys/public_key.pem

# App
APP_NAME=CodeMix NLP Platform
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Frontend
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ML Model
MODEL_PATH=./ml/models/checkpoints/best_model
MODEL_NAME=xlm-roberta-large
MAX_LENGTH=128
BATCH_SIZE=16

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# OAuth (Optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Rate Limiting
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=60

# Cache
CACHE_TTL=3600

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=CodeMix NLP
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000
